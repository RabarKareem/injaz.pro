3:T1072,[{"@context":"https://schema.org","@type":"Organization","name":"إنجاز ERP","alternateName":"Injaz ERP","url":"https://injaz.pro","logo":"https://injaz.pro/logo.png","contactPoint":[{"@type":"ContactPoint","telephone":"+9647500221000","contactType":"sales","areaServed":"IQ","availableLanguage":["ar","en"]}]},{"@context":"https://schema.org","@type":"WebSite","name":"Injaz ERP","url":"https://injaz.pro","inLanguage":"ar-IQ"},{"@context":"https://schema.org","@type":"SoftwareApplication","name":"إنجاز ERP","applicationCategory":"BusinessApplication","operatingSystem":"Web","description":"نظام إدارة موارد مؤسسات عراقي متقدم يربط المحاسبة والمخزون والمبيعات والموارد البشرية في منصة واحدة.","url":"https://injaz.pro","offers":{"@type":"Offer","availability":"https://schema.org/InStock","priceCurrency":"USD","price":"0","description":"Custom quotation based on scope"},"provider":{"@type":"Organization","name":"Jiasaz","url":"https://jiasaz.com","foundingDate":"2015"}},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"ما هو إنجاز ERP؟","acceptedAnswer":{"@type":"Answer","text":"إنجاز ERP هو نظام إدارة موارد مؤسسات عراقي متقدم صُمم خصيصاً لخدمة الشركات العراقية. يربط المحاسبة والمخزون والمبيعات والموارد البشرية والتقارير في منصة واحدة متكاملة."}},{"@type":"Question","name":"هل إنجاز ERP مناسب لنوع شركتي؟","acceptedAnswer":{"@type":"Answer","text":"نعم، إنجاز ERP صُمم ليخدم قطاعات متعددة تشمل التصنيع والتجارة العامة والأدوية والأغذية والأعمال الخدمية وغيرها. المنصة مرنة وقابلة للتخصيص حسب طبيعة نشاطك."}},{"@type":"Question","name":"كيف يختلف إنجاز عن الأنظمة العالمية مثل Odoo؟","acceptedAnswer":{"@type":"Answer","text":"إنجاز ERP صُمم من البداية للسوق العراقي، مما يعني ملاءمة أكبر لاحتياجاتك المحلية، ودعم مباشر من الشركة المطورة، وتخصيص أسرع، وتكلفة أكثر ذكاءً بدون رسوم لكل مستخدم."}},{"@type":"Question","name":"هل يوفر إنجاز ERP دعماً فنياً؟","acceptedAnswer":{"@type":"Answer","text":"نعم، يوفر إنجاز دعماً محلياً مباشراً من الفريق المطور نفسه. لا وسطاء ولا تذاكر انتظار بعيدة — تتحدث مباشرة مع من بنى النظام ويفهم سوقك."}},{"@type":"Question","name":"هل يمكن تخصيص النظام حسب احتياجات شركتي؟","acceptedAnswer":{"@type":"Answer","text":"بالتأكيد، المرونة في التخصيص هي أحد أهم مميزات إنجاز ERP. بما أن الفريق المطور محلي وقريب، فإن التخصيص يتم بسرعة أعلى وبفهم أعمق لاحتياجاتك."}},{"@type":"Question","name":"ما تكلفة إنجاز ERP؟","acceptedAnswer":{"@type":"Answer","text":"إنجاز ERP يوفر تسعيراً ذكياً ومرناً بدون أعباء رسوم لكل مستخدم. تواصل مع فريقنا للحصول على عرض مخصص يناسب حجم شركتك واحتياجاتك."}},{"@type":"Question","name":"هل يدعم النظام اللغة العربية بالكامل؟","acceptedAnswer":{"@type":"Answer","text":"نعم، إنجاز ERP بُني بواجهة عربية كاملة من الأساس، وليس مجرد ترجمة لنظام أجنبي. كل شيء من القوائم للتقارير مصمم باللغة العربية."}},{"@type":"Question","name":"هل يدعم النظام تعدد الفروع والشركات؟","acceptedAnswer":{"@type":"Answer","text":"نعم، يدعم إنجاز ERP إدارة فروع وشركات متعددة من منصة واحدة، مع صلاحيات وتقارير منفصلة لكل فرع."}}]}]0:{"P":null,"b":"q5vqjdvrzrLUuZ6c8M6-G","c":["","_not-found"],"q":"","i":false,"f":[[["",{"children":["/_not-found",{"children":["__PAGE__",{}]}]},"$undefined","$undefined",true],[["$","$1","c",{"children":[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/chunks/55fa930f1cde2b3c.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}],["$","link","1",{"rel":"stylesheet","href":"/_next/static/chunks/8ca0f842a8536b96.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}],["$","script","script-0",{"src":"/_next/static/chunks/c42ec2690dc021fe.js","async":true,"nonce":"$undefined"}],["$","script","script-1",{"src":"/_next/static/chunks/dca38569732fb997.js","async":true,"nonce":"$undefined"}],["$","script","script-2",{"src":"/_next/static/chunks/e4e4c8750013600d.js","async":true,"nonce":"$undefined"}]],["$","html",null,{"lang":"ar","dir":"rtl","children":[["$","head",null,{"children":[["$","$L2",null,{"src":"https://